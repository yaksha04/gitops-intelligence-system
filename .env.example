# Gemini API Key — get it FREE at: https://aistudio.google.com
GEMINI_API_KEY=paste_your_gemini_api_key_here

# GitHub Token — github.com > Settings > Developer Settings > Personal Access Tokens
GITHUB_TOKEN=paste_your_github_token_here

# Database — uses SQLite by default, no installation needed
DATABASE_URL=sqlite:///data/deployments.db

# Your GitHub repository name (format: username/repo-name)
GITHUB_REPO=yourusername/gitops-intelligence
